#General system specifications
SystemName          Au28S2C10H20 molecule
SystemLabel         ausc10hs
NumberOfAtoms       60
NumberOfSpecies     4

# Species index, atomic number, species label
%block ChemicalSpeciesLabel
 1  79 Au
 2  16 S
 3   6 C
 4   1 H
%endblock ChemicalSpeciesLabel

